{
	"luci-app-mddns-script": {
		"description": "Grant UCI access for luci-app-mddns-script",
		"read": {
			"uci": [ "mddns-script" ],
			"ubus": {
				"service": [ "list" ]
			},
			"file": {
				"/usr/sbin/mddns-script": [ "exec" ],
				"/*": [ "read" ]
			}
		},
		"write": {
			"file": {
				"/*": [ "write" ]
			}
		}
	}
}